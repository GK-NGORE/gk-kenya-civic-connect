{
  "version": 2,
  "builds": [
    {
      "src": "next.config.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXTAUTH_URL": "https://your-vercel-app.vercel.app",
    "NEXTAUTH_SECRET": "{{NEXTAUTH_SECRET}}",
    "MONGODB_URI": "{{MONGODB_URI}}"
  }
}
